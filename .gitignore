# =============================================================================
# Virtual environment
# =============================================================================
.venv/
venv/
env/
ENV/

# =============================================================================
# Python bytecode & caches
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
.mypy_cache/
.ruff_cache/
.pytype/

# =============================================================================
# Runtime data — generated by the pipeline
# =============================================================================

# SQLite database (contains metadata + deletion history; large, machine-specific)
*.db
*.db-wal
*.db-shm

# Organised output tree (actual image files + symlinks; up to 20+ GB)
output/

# DINOv2 / ArcFace embeddings (.npy files; regenerated by Phase 3)
*.npy
embeddings/

# Pipeline log files
*.log
run.log

# =============================================================================
# ML model weights (large binaries — downloaded automatically at runtime)
# =============================================================================
*.pt
*.pth
*.onnx
*.pkl
*.h5
*.weights

# =============================================================================
# HuggingFace & Ultralytics local caches
# (these should live in ~/.cache, but guard against accidental local copies)
# =============================================================================
.cache/
models/
weights/

# =============================================================================
# OS artefacts
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
# Editor & IDE
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# =============================================================================
# Distribution / packaging (not relevant here, but standard Python practice)
# =============================================================================
dist/
build/
*.egg-info/
*.egg
MANIFEST

# =============================================================================
# Environment variable files (never commit secrets)
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Jupyter (if notebooks are added later)
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Test artefacts (if tests are added later)
# =============================================================================
.pytest_cache/
htmlcov/
.coverage
coverage.xml
